{
  "name": "sudachi-lookup",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "preview": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "build:pages": "node tools/site/build-pages.mjs",
    "preview:pages": "vite preview --config vite.pages.config.ts",
    "deploy:pages:staging": "npm run build:pages -- --edition sample && node tools/site/deploy-pages.mjs --branch staging",
    "deploy:pages:core-staging": "npm run data:core:validate && npm run build:pages -- --edition core && node tools/site/deploy-pages.mjs --branch core-staging",
    "deploy:pages:full-staging": "npm run data:full:validate && npm run build:pages -- --edition full && node tools/site/deploy-pages.mjs --branch full-staging",
    "deploy:pages:full-production": "npm run data:full:validate && npm run build:pages -- --edition full && node tools/site/deploy-pages.mjs --branch main",
    "data:sample": "node tools/dictionary/build-sample.mjs",
    "data:release:check": "node tools/dictionary/check-release-config.mjs",
    "data:small:install": "SUDACHI_EDITION=small node tools/dictionary/install-official-dictionary.mjs",
    "data:small": "SUDACHI_EDITION=small node tools/dictionary/export-dictionary.mjs",
    "data:core:install": "SUDACHI_EDITION=core node tools/dictionary/install-official-dictionary.mjs",
    "data:core": "SUDACHI_EDITION=core node tools/dictionary/export-dictionary.mjs",
    "data:core:web": "SUDACHI_EDITION=core node tools/dictionary/build-dictionary-web.mjs",
    "data:full": "SUDACHI_EDITION=full node tools/dictionary/export-dictionary.mjs",
    "data:full:web": "SUDACHI_EDITION=full node tools/dictionary/build-dictionary-web.mjs",
    "data:editions:verify": "node tools/dictionary/verify-edition-prefixes.mjs",
    "data:core:validate": "SUDACHI_EDITION=core node tools/dictionary/validate-web.mjs",
    "data:full:install": "SUDACHI_EDITION=full node tools/dictionary/install-official-dictionary.mjs",
    "data:full:validate": "SUDACHI_EDITION=full node tools/dictionary/validate-web.mjs",
    "docs:check": "node tools/docs/check-locales.mjs",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run data:release:check && npm run docs:check && npm run data:sample && npm test && tsc --noEmit && npm run build && npm run build:pages -- --edition sample"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
